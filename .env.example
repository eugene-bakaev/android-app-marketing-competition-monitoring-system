# Database (Neon in prod, local postgres in dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_monitor

# Redis (Upstash in prod, local redis in dev)
REDIS_URL=redis://localhost:6379

# AWS S3 (optional — when not set, screenshots are stored locally)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=app-monitor-screenshots

# API
API_PORT=3001

# Worker
WORKER_CONCURRENCY=2

# Scraper timeouts (optional, defaults shown)
# SCRAPER_PAGE_TIMEOUT_MS=30000
# SCRAPER_SELECTOR_TIMEOUT_MS=10000
